---
import SectionHeader from "../primitives/SectionHeader.astro";
import { site } from "../../data/site";
---

<section id="contact">
  <div class="container">
    <SectionHeader
      eyebrow="Next step"
      title="Book a 30-minute intro call."
      subtitle="No pitch deck, no sales pressure. We talk through your audience, your channel goals, and whether the system fits. If it does, you get a proposal within 48 hours."
    />
    <div class="content cta-block">
      <a href={site.contact.calendly} class="cta-primary" target="_blank" rel="noopener noreferrer">
        Book intro call →
      </a>
      <p class="alt">
        Or email <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      </p>
    </div>
  </div>
</section>

<style>
  .cta-block {
    text-align: center;
    padding: var(--space-12) 0;
  }
  .cta-primary {
    display: inline-block;
    background: var(--accent);
    color: #FFFFFF;
    padding: var(--space-4) var(--space-8);
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 1.125rem;
  }
  .cta-primary:hover { background: var(--accent-hover); color: #FFFFFF; }
  .alt {
    margin-top: var(--space-6);
    color: var(--text-muted);
  }
</style>
