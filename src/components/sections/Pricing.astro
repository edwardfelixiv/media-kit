---
import SectionHeader from "../primitives/SectionHeader.astro";
import PricingCard from "../primitives/PricingCard.astro";
import { pricing } from "../../data/pricing";
---

<section id="pricing">
  <div class="container">
    <SectionHeader
      eyebrow="Pricing"
      title="Three tiers. Month-to-month."
      subtitle="No long-term contracts. Upgrade, downgrade, or cancel before your next billing cycle."
    />
    <div class="grid">
      {pricing.map((tier) => <PricingCard tier={tier} />)}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
  }

  @media print {
    .grid { grid-template-columns: 1fr; gap: var(--space-4); }
  }
</style>
