---
import type { PricingTier } from "../../data/pricing";

interface Props {
  tier: PricingTier;
}

const { tier } = Astro.props;
---

<article class={`pricing-card ${tier.highlighted ? "highlighted" : ""}`}>
  {tier.highlighted && <div class="badge">Most popular</div>}
  <h3>{tier.name}</h3>
  <p class="tagline">{tier.tagline}</p>
  <div class="price">
    <span class="amount">{tier.price}</span>
    <span class="cadence">{tier.cadence}</span>
  </div>
  <ul>
    {tier.features.map((f) => <li>{f}</li>)}
  </ul>
</article>

<style>
  .pricing-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
  }
  .pricing-card.highlighted {
    border-color: var(--accent);
    background: var(--surface-elevated);
  }
  .badge {
    position: absolute;
    top: -12px;
    right: var(--space-6);
    background: var(--accent);
    color: #FFFFFF;
    font-size: var(--text-small);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    font-weight: 500;
  }
  h3 {
    font-size: var(--text-h2);
    margin-bottom: 0;
  }
  .tagline {
    color: var(--text-muted);
    font-size: var(--text-small);
  }
  .price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-2) 0;
  }
  .amount {
    font-size: 2.25rem;
    font-weight: 600;
    color: var(--text);
  }
  .cadence {
    color: var(--text-muted);
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  li {
    color: var(--text-muted);
    padding-left: var(--space-6);
    position: relative;
    margin-bottom: 0;
  }
  li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
</style>
